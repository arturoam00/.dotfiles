#!/bin/sh

# Date and time
date=$(date +'%a, %d %B пЃі | %I:%M %p')

# Battery percentage #
battery=$(cat /sys/class/power_supply/BAT0/capacity)%
bat_status=$(cat /sys/class/power_supply/BAT0/status)
if [[ $bat_status == "Discharging" ]]; then
    battery_icon="у°Ѓ№"
else
    battery_icon="у°‚„"
fi

# Network state #

# networkctl output
output=$(networkctl status --no-pager)

# network state
net_state=$(printf '%s\n' "$output" | awk '/State:/ {print $2}')

case $net_state in
    routable) net_state="online" ;;
    *)        net_state="offline" ;;
esac

if [ "$net_state" = "offline" ]; then
    network="у°–Є" 
fi

nif=$(printf '%s\n' "$output" | awk '/Address:/ {print $4}')
case $nif in
    wlan*)
        iw=$(iwctl station wlan0 show 2>/dev/null)
        ssid=$(printf '%s\n' "$iw" | sed -n 's/.*Connected network[[:space:]]\+//p' | xargs)
        network="$ssid у°–©"
        ;;
    enp*)
        network="Ethernet online у°€Ђ"
        ;;
esac

# Bluetooth #
bluetooth_devices=$(bluetoothctl devices Connected 2>/dev/null | wc -l)

# Microphone
if wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null | grep -q "MUTED"; then
    micro="п„± "
else
    micro="п„°"
fi

# Speaker
if wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -q "MUTED"; then
    speaker="у°–Ѓ"
else 
    speaker="у°•ѕ"
fi

echo "$speaker | $micro | $bluetooth_devices пЉ“ | $network | $battery $battery_icon | $date пЂ— "
