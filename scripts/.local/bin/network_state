#!/bin/sh

# networkctl output
output=$(networkctl status --no-pager)

# network state
state=$(printf '%s\n' "$output" | awk '/State:/ {print $2}')

case $state in
    routable) state="online" ;;
    *)        state="offline" ;;
esac

if [ "$state" = "offline" ]; then
    echo "蟀柂" 
    exit 0
fi

nif=$(printf '%s\n' "$output" | awk '/Address:/ {print $4}')
case $nif in
    wlan*)
        iw=$(iwctl station wlan0 show 2>/dev/null)
        ssid=$(printf '%s\n' "$iw" | sed -n 's/.*Connected network[[:space:]]\+//p' | xargs)
        echo "$ssid 蟀柀"
        ;;
    enp*)
        echo "Ethernet online 蟀垁"
        ;;
esac

