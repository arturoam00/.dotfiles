#!/bin/bash
set -eu

# Get all trusted devices that are disconnected
trusted_disconnected=$(comm -3 <(bluetoothctl devices Trusted | sort) <(bluetoothctl devices Connected | sort))

# Get only connected devices and append an connection identifier string
connected="$(bluetoothctl devices Connected | sed 's/$/ (c)/')"

# Group all devices and prepend id string
devices=$(echo -e "$trusted_disconnected\n$connected" | sort | awk '{print NR": "$0}')

# Get the id of the device to connect/disconnect
id=$(echo "$devices" | cut -d' ' -f1,4- | tofi | grep -oP '^\d{1,2}')

# Get the full string, including the uuid
target=$(echo "$devices" | grep -P "^$id")

# Extract the uuid from the target
uuid=$(echo "$target" | cut -d' ' -f3)

# Prepare label string for notification message
label=$(echo "$target" | cut -d' ' -f4- | sed 's/ (c)//')

# Decide operation based on current state
if [[ $target == *\(c\)* ]]; then 
    action=disconnect
else
    action=connect
fi

# Perform operation
if bluetoothctl $action "$uuid"> /dev/null; then
    dunstify \
        -a "bluetooth" \
        -i "bluetooth-active" \
        -u normal \
        "Bluetooth" "$label ${action}ed ✓"
else
    dunstify \
        -a "bluetooth" \
        -u critical \
        "Bluetooth" "Couldn't $action $label "
fi

