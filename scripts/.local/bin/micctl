#!/usr/bin/env bash

set -euo pipefail

[[ "$#" -ne 1 ]] && echo 'provide one argument' && exit 1

tag="microphone_tag"
step=5

read -r vol muted < <(
    wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | awk '/Volume/ {print $2, ($3 == "[MUTED]")}'
)
vol=$(awk -v vol=$vol 'BEGIN { print vol * 100 }')

case $1 in
  up)
    wpctl set-volume @DEFAULT_AUDIO_SOURCE@ "$step"%+ --limit 1.0
    icon="microphone-sensitivity-high"
    vol=$(($vol + $step))
    ;;
  down)
    wpctl set-volume @DEFAULT_AUDIO_SOURCE@ "$step"%- --limit 1.0
    icon="microphone-sensitivity-low"
    vol=$(($vol - $step))
    ;;
  mute)
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
    muted=$(( 1 - $muted ))
    if [[ $muted == 1 ]]; then
        icon="microphone-sensitivity-muted"
        msg="Microphone muted"
    else
        icon="audio-input-microphone"
        msg="Microphone unmuted"
    fi
    dunstify -a "volume" -i $icon -h string:x-dunst-stack-tag:$tag "Microphone" "$msg"
    exit 0
    ;;
  *)
    echo 'unrecognized argument'
    exit 1
esac

vol=$(awk -v vol=$vol 'BEGIN {
    if (vol < 0) vol = 0
    if (vol > 100) vol = 100
    print vol
}')

if [[ $vol -eq 0 || $muted -eq 1 ]]; then
    icon="microphone-sensitivity-muted"
fi

dunstify \
    -a "volume" \
    -u normal \
    -i $icon \
    -h string:x-dunst-stack-tag:$tag \
    "Microphone" "Volume: $vol"%

