# In Mac this doesn't appear to load automatically
[[ -f $ZDOTDIR/.zshenv ]] && source $ZDOTDIR/.zshenv

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

export EDITOR=nvim
export OPENER=open
export BROWSER=firefox
export ZSH_AUTOSUGGEST_PATH="/opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
export ZSH_HIGHLIGHT_PATH="/opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
export HOMEBREW_NO_ENV_HINTS=1
export XDG_DOWNLOAD_DIR=$HOME/Downloads
export XDG_DOCUMENTS_DIR=$HOME/Documents
export XDG_PICTURES_DIR=$HOME/Pictures

brew() {
  command brew "$@"
  local result=$?

  if (( result == 0 )); then
    case "$1" in
      install|uninstall|remove|rm|reinstall|tap|untap)
        command brew bundle dump \
          --file="$HOME/.Brewfile" \
        ;;
    esac
  fi

  return $result
}

touch $XDG_DOCUMENTS_DIR/notes/$(date +'%Y-%m-%d').md
