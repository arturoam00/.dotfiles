# In Mac this doesn't appear to load automatically
[[ -f $ZDOTDIR/.zshenv ]] && source $ZDOTDIR/.zshenv


if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

EDITOR=nvim
OPENER=open
BROWSER=firefox
ZSH_AUTOSUGGEST_PATH="/opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
ZSH_HIGHLIGHT_PATH="/opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
HOMEBREW_NO_ENV_HINTS=1
