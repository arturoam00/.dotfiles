#!/bin/sh

absolute_path() {
    if command -v realpath >/dev/null 2>&1; then
        realpath "$1" 2>/dev/null && return
    fi

    case "$1" in
        /*) printf '%s\n' "$1" ;;
        *)
            directory=$(dirname "$1")
            basename=$(basename "$1")
            (cd -P "$directory" 2>/dev/null && printf '%s/%s\n' "$PWD" "$basename")
            ;;
    esac
}

checksum() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum | awk '{print $1}'
    else
        shasum -a 256 | awk '{print $1}'
    fi
}

cache_key() {
    path=$(absolute_path "$1")
    if stat -f '%N:%i:%HT:%z:%B:%m' "$path" >/dev/null 2>&1; then
        stat -f '%N:%i:%HT:%z:%B:%m' "$path" | checksum
    else
        stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$path" | checksum
    fi
}

image() {
    file_path=$1
    x=$4
    y=$5
    max_width=$(( $2 - 1 ))
    max_height=$3

    preview_available || return 1
    ueberzugpp cmd -s "$UB_SOCKET" -a add -i PREVIEW \
        -x "$x" -y "$y" --max-width "$max_width" --max-height "$max_height" \
        -f "$file_path"
}

preview_available() {
    [ -n "${UB_SOCKET:-}" ] && command -v ueberzugpp >/dev/null 2>&1
}

identify_orientation() {
    if command -v magick >/dev/null 2>&1; then
        magick identify -format '%[orientation]\n' "$1[0]" 2>/dev/null
    elif command -v identify >/dev/null 2>&1; then
        identify -format '%[orientation]\n' "$1[0]" 2>/dev/null
    fi
}

auto_orient() {
    if command -v magick >/dev/null 2>&1; then
        magick "$1[0]" -auto-orient "$2"
    else
        convert "$1[0]" -auto-orient "$2"
    fi
}

render_image() {
    preview_available || return 1
    orientation=$(identify_orientation "$1")
    if [ -n "$orientation" ] && [ "$orientation" != Undefined ] && [ "$orientation" != TopLeft ]; then
        if [ ! -f "${CACHE}.jpg" ]; then
            mkdir -p "$(dirname "${CACHE}.jpg")" || return 1
            auto_orient "$1" "${CACHE}.jpg" || return 1
        fi
        image "${CACHE}.jpg" "$2" "$3" "$4" "$5"
    else
        image "$1" "$2" "$3" "$4" "$5"
    fi
}

image_from_cache() {
    preview_available || return 1
    output=${CACHE}.jpg
    if [ ! -f "$output" ]; then
        mkdir -p "$(dirname "$output")" || return 1
        "$@" || return 1
    fi
    image "$output" "$WIDTH" "$HEIGHT" "$X" "$Y"
}

batorcat() {
    if command -v bat >/dev/null 2>&1; then
        bat --color=always --style=plain --paging=never -- "$1"
    else
        cat -- "$1" 2>/dev/null || cat "$1"
    fi
}

highlight_csv() {
    if command -v bat >/dev/null 2>&1; then
        bat --color=always --style=plain --paging=never --language=csv
    else
        cat
    fi
}

describe() {
    file -Lb -- "$FILE" | fold -s -w "$WIDTH"
}

FILE=$1
WIDTH=$2
HEIGHT=$3
X=$4
Y=$5
PATHNAME=$(absolute_path "$FILE")
CACHE="$HOME/.cache/lf/thumbnail.$(cache_key "$FILE")"

case "$(printf '%s\n' "$PATHNAME" | tr '[:upper:]' '[:lower:]')" in
    *.tgz | *.tar.gz) tar tzf "$FILE"; exit ;;
    *.tar.bz2 | *.tbz2) tar tjf "$FILE"; exit ;;
    *.tar.txz | *.txz) xz --list "$FILE"; exit ;;
    *.tar) tar tf "$FILE"; exit ;;
    *.zip | *.jar | *.war | *.ear | *.oxt) unzip -l "$FILE"; exit ;;
    *.rar) unrar l "$FILE"; exit ;;
    *.7z) 7z l "$FILE"; exit ;;
    *.[1-8]) man "$FILE" | col -b; exit ;;
    *.o) nm "$FILE"; exit ;;
    *.torrent) transmission-show "$FILE"; exit ;;
    *.iso) iso-info --no-header -l "$FILE"; exit ;;
    *.odt | *.ods | *.odp | *.sxw) odt2txt "$FILE"; exit ;;
    *.doc) catdoc "$FILE"; exit ;;
    *.docx) docx2txt "$FILE" -; exit ;;
    *.xls | *.xlsx)
        ssconvert --export-type=Gnumeric_stf:stf_csv "$FILE" 'fd://1' | highlight_csv
        exit
        ;;
    *.wav | *.mp3 | *.flac | *.m4a | *.wma | *.ape | *.ac3 | *.og[agx] | *.spx | *.opus | *.as[fx] | *.mka)
        exiftool "$FILE"
        exit
        ;;
    *.pdf)
        image_from_cache pdftoppm -jpeg -f 1 -singlefile "$FILE" "$CACHE" && exit 1
        ;;
    *.avi | *.mp4 | *.wmv | *.dat | *.3gp | *.ogv | *.mkv | *.mpg | *.mpeg | *.vob | *.fl[icv] | *.m2v | *.mov | *.webm | *.ts | *.mts | *.m4v | *.r[am] | *.qt | *.divx)
        image_from_cache ffmpegthumbnailer -i "$FILE" -o "${CACHE}.jpg" -s 0 -q 5 && exit 1
        ;;
    *.bmp | *.jpg | *.jpeg | *.png | *.xpm | *.webp | *.gif | *.jfif)
        render_image "$FILE" "$WIDTH" "$HEIGHT" "$X" "$Y" && exit 1
        ;;
    *.svg)
        if command -v magick >/dev/null 2>&1; then
            image_from_cache magick "$FILE" "${CACHE}.jpg" && exit 1
        else
            image_from_cache convert "$FILE" "${CACHE}.jpg" && exit 1
        fi
        ;;
esac

case "$(file -Lb --mime-type -- "$FILE")" in
    image/*)
        render_image "$FILE" "$WIDTH" "$HEIGHT" "$X" "$Y" && exit 1
        ;;
    video/*)
        image_from_cache ffmpegthumbnailer -i "$FILE" -o "${CACHE}.jpg" -s 0 -q 5 && exit 1
        ;;
    text/*)
        batorcat "$FILE"
        exit
        ;;
    audio/*)
        exiftool "$FILE"
        exit
        ;;
    application/pdf)
        image_from_cache pdftoppm -jpeg -f 1 -singlefile "$FILE" "$CACHE" && exit 1
        ;;
esac

describe
exit 0
